@{
    ViewData["Title"] = "Projects";
}
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sachin Chaurasiya | Projects</title>
    <link rel="stylesheet" href="/css/Projectsheet.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <a asp-controller="Dashboard" asp-action="Index" class="back-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back
    </a>
    @if (ViewBag.Role?.ToString() == "ADMIN")
    {
        <a asp-controller="Project" asp-action="ProjectEdit" class="Edit-btn">
            Edit
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
        </a>
    }
    <section class="projects-section">
        <h1 class="section-title">My Projects</h1>
        <div class="projects-grid">

            <div class="project-card hidden">
                <div class="project-image">
                    <img src="/uploads/system-design-for-ecommerce.webp" alt="E-commerce Backend">

                </div>
                <div class="project-content">
                    <h3>.Net core MVC Portfolio</h3>
                    <p>A .Net based portfolio website featuring MVC and Introduction</p>
                    <div class="tags">
                        <span>Html,Css </span><span>.Net Core</span><span>javascript</span>
                    </div>
                    <a href="https://github.com/Sachin-Chaurasiya12/.Net_Core_MVC_Portfolio" target="_blank" class="github-link">
                        View Source Code
                    </a>
                </div>
            </div>

            <div class="project-card hidden">
                <div class="project-image">
                    <img src="/uploads/portfolio-button-speech-bubble-banner-label-portfolio-vector.jpg" alt="Portfolio">

                </div>
                <div class="project-content">
                    <h3>E-commerce Backend System</h3>
                    <p>A scalable REST API built with Spring Boot, featuring JWT authentication, order management, and SQL integration.</p>
                    <div class="tags">
                        <span>Spring Boot</span><span>MySQL</span><span>JWT</span>
                    </div>
                    <a href="https://github.com/Sachin-Chaurasiya12/Ecommerce_Backend_System" target="_blank" class="github-link">
                        View Source Code
                    </a>
                </div>
            </div>


        </div>
        <br />
        <footer class="portfolio-footer">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>Sachin Chaurasiya</h3>
                    <p>Backend Developer specializing in Java, Spring Boot, and .NET Core.</p>
                </div>

                <div class="footer-links">
                    <a href="mailto:your-email@example.com" title="Email Me">
                        <i class="fas fa-envelope"></i>
                    </a>
                    <a href="https://github.com/yourusername" target="_blank" title="GitHub">
                        <i class="fab fa-github"></i>
                    </a>
                    <a href="https://linkedin.com/in/yourusername" target="_blank" title="LinkedIn">
                        <i class="fab fa-linkedin"></i>
                    </a>
                </div>
            </div>

            <div class="footer-bottom">
                <p>&copy; 2026 | Designed & Built with ❤️</p>
            </div>
        </footer>
    </section>

    <script src="/js/Projectscript.js"></script>
</body>
</html>