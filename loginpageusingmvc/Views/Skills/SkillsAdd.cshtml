@{
    Layout = null;
}
@model loginpageusingmvc.DTOs.SkillCreateDTO
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Skill</title>
    <link rel="stylesheet" href="/css/SkillStyle.css" />
    <style>
        .form-container {
            max-width: 500px;
            margin: 100px auto;
            background: #1e293b;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }
        .form-group { margin-bottom: 20px; }
        label { display: block; margin-bottom: 8px; color: #94a3b8; }
        input, select {
            width: 100%;
            padding: 12px;
            background: #0f172a;
            border: 1px solid #334155;
            color: white;
            border-radius: 8px;
        }
        .submit-btn {
            width: 100%;
            padding: 12px;
            background: #1e3a8a;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.3s;
        }
        .submit-btn:hover { background: #3b82f6; }
        .error { color: #ef4444; font-size: 13px; margin-top: 5px; }
    </style>
</head>
<body>
    <a asp-action="Skillspage" class="back-btn">Cancel</a>

    <div class="form-container">
        <h2 style="margin-bottom: 20px; text-align: center;">Add New Skill</h2>

        <form asp-action="AddSkills" method="post">
            <div class="form-group">
                <label>Skill Name</label>
                <input asp-for="Title" placeholder="e.g. ASP.NET Core" />
                <span asp-validation-for="Title" class="error"></span>
            </div>

            <div class="form-group">
                <label>Proficiency (%)</label>
                <input asp-for="Percentage" type="number" placeholder="85" />
                <span asp-validation-for="Percentage" class="error"></span>
            </div>

            <div class="form-group">
                <label>Category</label>
                <select asp-for="Category">
                    <option value="frontend">Frontend</option>
                    <option value="backend">Backend</option>
                    <option value="tools">Tools</option>
                </select>
                <span asp-validation-for="Category" class="error"></span>
            </div>

            <button type="submit" class="submit-btn">Save Skill</button>
        </form>
        @if (ViewBag.display != null)
        {
            <div class="message-display">
                @ViewBag.display
            </div>
        }
    </div>
</body>
</html>