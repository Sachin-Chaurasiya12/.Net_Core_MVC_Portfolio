@{
    ViewData["Title"] = "Dashborad";
}
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Personal Portfolio Dashboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/StyleSheet1.css">
</head>
<body>

    <div class="container">

        <!-- Sidebar -->
        <aside class="sidebar">
            <h2>SACHIN<br />PORTFOLIO</h2>

            <div class="profile-section">
                <a asp-controller="Dashboard" asp-action="EditProfile">
                    <img src="@(Model?.ProfileImagePath ?? "/uploads/Default-welcomer.png")" alt="Profile" class="avatar-img" />
                </a>
                @* <p class="profile-name">@Model?.Name (@Model?.Role)</p> *@
                @if (Model?.Role == "ADMIN")
                {
                    <p class="profile-name">@Model.Name (Admin)</p>
                }
                else
                {
                    <p class="profile-name">@Model?.Name</p>
                }
            </div>

            <ul>
                <li onclick="location.href='@Url.Action("Index", "Dashboard")'" class="active">Dashboard</li>
                <li onclick="location.href='@Url.Action("projectIndex","Project")'">Projects</li>
                <li onclick="location.href='@Url.Action("Skillspage","Skills")'">Skills</li>
                <li onclick="location.href='@Url.Action("ContactPage","Contact")'">Contact</li>

                <li class="logout-item">
                    <a asp-controller="Account" asp-action="Logout" style="color: inherit; text-decoration: none; display: block; width: 100%;">
                        Logout
                    </a>
                </li>
            </ul>
            </aside>


        <!-- Main -->
        <main class="main">

            <header>
                <h1>Personal Dashboard</h1>
            </header>

            <!-- Charts -->
            <div class="charts">
                <canvas id="lineChart"></canvas>
                <canvas id="pieChart"></canvas>
            </div>

            <!-- Cards -->
            <div class="cards">
                <div class="card">
                    <h3>5+</h3>
                    <span>Projects Built</span>
                </div>
                <div class="card">
                    <h3>80+</h3>
                    <span>Git Commits</span>
                </div>
                <div class="card">
                    <h3>12</h3>
                    <span>Tech Skills</span>
                </div>
                <div class="card">
                    <h3>2</h3>
                    <span>Certificates</span>
                </div>
            </div>

            <!-- Skills -->
            <div class="skills">
                <h2>Skills</h2>

                <div class="bar">
                    <p>Frontend</p>
                    <div class="progress"><span style="width:50%"></span></div>
                </div>

                <div class="bar">
                    <p>Backend</p>
                    <div class="progress"><span style="width:75%"></span></div>
                </div>

                <div class="bar">
                    <p>Database</p>
                    <div class="progress"><span style="width:75%"></span></div>
                </div>

            </div>

        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1"></script>
    <script src="~/js/boardscript.js"></script>
</body>
</html>