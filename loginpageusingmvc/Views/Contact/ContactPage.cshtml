@{
    ViewData["Title"] = "Contact";
}
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us</title>
    <link rel="stylesheet" href="~/css/ContactStyle.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <p>@ViewBag.Show</p>
    <div class="container">
        <a href="javascript:history.back()" class="back-btn">
            <i class="fas fa-arrow-left"></i> Back to Home
        </a>

        <div class="contact-box">
            <div class="contact-info">
                <h2>Get in Touch</h2>
                <p>Have a project in mind? We'd love to hear from you.</p>
                <div class="info-item">
                    <i class="fas fa-envelope"></i>
                    <span>sachinchau444@gmail.com</span>
                </div>
                <div class="info-item">
                    <i class="fas fa-phone"></i>
                    <span>+91 9833724659</span>
                </div>
            </div>

            <form id="contactForm" asp-action="ContactForm" method="post" class="contact-form">
                <div class="input-group">
                    <input type="text" id="name" required placeholder="Full Name">
                </div>
                <div class="input-group">
                    <input type="email" id="email" required placeholder="Email Address">
                </div>
                <div class="input-group">
                    <input type="text" id="subject" required placeholder="Subject">
                </div>
                <div class="input-group">
                    <textarea id="message" rows="5" required placeholder="Your Message"></textarea>
                </div>
                <button type="submit" class="submit-btn">Send Message</button>
            </form>
        </div>
    </div>

    <script src="~/js/Contactscript.js"></script>
</body>
</html>